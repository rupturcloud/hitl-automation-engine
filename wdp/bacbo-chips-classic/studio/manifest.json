{
  "manifest_version": 3,
  "name": "Bet IA - Soberania Modular",
  "version": "2.0.4",
  "description": "Motor de Automação Inteligente para Bancas e Robôs de Apostas.",
  "permissions": ["sidePanel", "tabs", "scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Abrir Bet IA"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
