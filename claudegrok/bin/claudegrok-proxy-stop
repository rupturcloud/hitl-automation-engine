#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="$ROOT/.claude/claudegrok_proxy.pid"
if [[ -f "$PID_FILE" ]]; then
  PID="$(cat "$PID_FILE")"
  if kill "$PID" >/dev/null 2>&1; then
    echo "Proxy encerrado: $PID"
  else
    echo "Processo do PID file não estava rodando: $PID"
  fi
  rm -f "$PID_FILE"
else
  echo "Sem PID file em $PID_FILE"
fi
